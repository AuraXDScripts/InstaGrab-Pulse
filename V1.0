end

local stealButton = createMainButton(150, "INSTANT STEAL", Color3.fromRGB(40, 40, 40))
local autoButton  = createMainButton(200, "AUTO SPAM: OFF", Color3.fromRGB(30, 30, 30))

local statusLabel = Instance.new("TextLabel", mainFrame)
statusLabel.Size = UDim2.new(1, -30, 0, 20)
statusLabel.Position = UDim2.new(0, 15, 1, -28)
statusLabel.BackgroundTransparency = 1
statusLabel.Text = "STATUS: IDLE"
statusLabel.TextColor3 = Color3.fromRGB(170,170,170)
statusLabel.TextSize = 13
statusLabel.Font = Enum.Font.Gotham

-- ====================== CORE LOGIC ======================
local function setProgress(percent, instant)
    TweenService:Create(progressBar, TweenInfo.new(instant and 0.04 or 0.55, Enum.EasingStyle.Quint), 
        {Size = UDim2.new(percent/100, 0, 1, 0)}):Play()
    progressText.Text = math.floor(percent) .. "%"
end

local function getHRP()
    if hrpCache and hrpCache.Parent then return hrpCache end
    local char = player.Character
    if char then hrpCache = char:FindFirstChild("HumanoidRootPart") end
    return hrpCache
end

local function rebuildAnimalCache()
    allAnimalsCache = {}
    local plots = Workspace:FindFirstChild("Plots")
    if not plots then return end
    for _, plot in ipairs(plots:GetChildren()) do
        local podiums = plot:FindFirstChild("AnimalPodiums")
        if podiums then
            for _, podium in ipairs(podiums:GetChildren()) do
                local spawn = podium:FindFirstChild("Base") and podium.Base:FindFirstChild("Spawn")
                if spawn then
                    local prompt = spawn.PromptAttachment:FindFirstChildOfClass("ProximityPrompt")
                    if prompt then
                        table.insert(allAnimalsCache, {worldPosition = podium:GetPivot().Position, prompt = prompt})
                    end
                end
            end
        end
    end
end

local function getNearestAnimal()
    local hrp = getHRP()
    if not hrp then return nil end
    local pos = hrp.Position
    local nearest, minDist = nil, math.huge
    for _, a in ipairs(allAnimalsCache) do
        local dist = (pos - a.worldPosition).Magnitude
        if dist < minDist and dist <= GRAB_RADIUS and a.prompt then
            minDist = dist
            nearest = a
        end
    end
    return nearest
end

local function trySteal(prompt)
    if not prompt or (os.clock() - (LastActionTime or 0)) < BASE_COOLDOWN then return end
    LastActionTime = os.clock()

    statusLabel.Text = "STEALING..."
    setProgress(100, true)

    pcall(function()
        prompt.HoldDuration = 0
        prompt:InputHoldBegin()
        task.wait(0.007)
        prompt:InputHoldEnd()
        prompt:InputTrigger()
        task.wait(0.007)
        prompt:InputTrigger()
    end)

    task.wait(BASE_COOLDOWN * 0.55)
    statusLabel.Text = "STATUS: IDLE"
    setProgress(0, true)
end

-- ====================== BUTTON LOGIC ======================
stealButton.MouseButton1Click:Connect(function()
    local animal = getNearestAnimal()
    if animal and animal.prompt then
        trySteal(animal.prompt)
    end
end)

autoButton.MouseButton1Click:Connect(function()
    AutoSpamEnabled = not AutoSpamEnabled
    autoButton.Text = AutoSpamEnabled and "AUTO SPAM: ON" or "AUTO SPAM: OFF"
end)

antiLagBtn.MouseButton1Click:Connect(function()
    antiLagEnabled = not antiLagEnabled
    antiLagBtn.Text = antiLagEnabled and "ANTI LAG: ON" or "ANTI LAG: OFF"
    antiLagBtn.BackgroundColor3 = antiLagEnabled and Color3.fromRGB(35,35,35) or Color3.fromRGB(25,25,25)
    applyAntiLag(antiLagEnabled)
end)

ultraBtn.MouseButton1Click:Connect(function()
    ultraModeEnabled = not ultraModeEnabled
    ultraBtn.Text = ultraModeEnabled and "ULTRA MODE: ON" or "ULTRA MODE: OFF"
    ultraBtn.BackgroundColor3 = ultraModeEnabled and Color3.fromRGB(35,35,35) or Color3.fromRGB(25,25,25)
    applyUltraMode(ultraModeEnabled)
end)

-- ====================== MAIN LOOP ======================
task.spawn(function()
    while true do
        task.wait(0.03)
        local animal = getNearestAnimal()
        
        if animal then
            if progressBar.Size.X.Scale < 0.85 then
                setProgress(88, false)
            end
            if AutoSpamEnabled then
                trySteal(animal.prompt)
            end
        else
            setProgress(0, true)
        end
    end
end)

task.spawn(function()
    task.wait(1.2)
    rebuildAnimalCache()
    while true do
        task.wait(13)
        rebuildAnimalCache()
    end
end)

print("Pulse Insta Grab - Progress sub frame + transparențe ajustate")
