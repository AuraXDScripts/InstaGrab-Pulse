-- =============================================================
-- Pulse Insta Grab - Anti Lag + Ultra Mode + Auto Spam (Alb-Negru Curat)
-- =============================================================
repeat task.wait() until game:IsLoaded()

local Players = game:GetService("Players")
local TweenService = game:GetService("TweenService")
local UserInputService = game:GetService("UserInputService")
local CoreGui = game:GetService("CoreGui")
local Workspace = game:GetService("Workspace")
local Lighting = game:GetService("Lighting")

local player = Players.LocalPlayer

-- ====================== SETTINGS ======================
local GRAB_RADIUS = 11
local BASE_COOLDOWN = 0.33

local AutoSpamEnabled = false
local allAnimalsCache = {}
local hrpCache = nil
local LastActionTime = 0

local antiLagEnabled = false
local ultraModeEnabled = false

-- Saved Original Settings
local originalSettings = {}
local originalDescendants = {}

local function saveOriginalSettings()
    originalSettings = {
        GlobalShadows = Lighting.GlobalShadows,
        FogEnd = Lighting.FogEnd,
        Brightness = Lighting.Brightness,
        EnvironmentDiffuseScale = Lighting.EnvironmentDiffuseScale,
        EnvironmentSpecularScale = Lighting.EnvironmentSpecularScale,
        ClockTime = Lighting.ClockTime,
        GeographicLatitude = Lighting.GeographicLatitude,
    }
end

local function restoreOriginalSettings()
    if next(originalSettings) == nil then return end
    
    Lighting.GlobalShadows = originalSettings.GlobalShadows or true
    Lighting.FogEnd = originalSettings.FogEnd or 100000
    Lighting.Brightness = originalSettings.Brightness or 1
    Lighting.EnvironmentDiffuseScale = originalSettings.EnvironmentDiffuseScale or 1
    Lighting.EnvironmentSpecularScale = originalSettings.EnvironmentSpecularScale or 1
    Lighting.ClockTime = originalSettings.ClockTime or 14
    Lighting.GeographicLatitude = originalSettings.GeographicLatitude or 23.5
end

local function applyAntiLag(enabled)
    if enabled then
        if next(originalSettings) == nil then saveOriginalSettings() end
        
        Lighting.GlobalShadows = false
        Lighting.FogEnd = 10000000
        Lighting.Brightness = 1.2
        Lighting.EnvironmentDiffuseScale = 0
        Lighting.EnvironmentSpecularScale = 0
        Lighting.ClockTime = 12
        Lighting.GeographicLatitude = 0

        for _, v in ipairs(Workspace:GetDescendants()) do
            if (v:IsA("BasePart") or v:IsA("MeshPart") or v:IsA("UnionOperation")) then
                if not v:FindFirstAncestorWhichIsA("Accessory") then
                    v.Material = Enum.Material.Plastic
                    v.Reflectance = 0
                    v.CastShadow = false
                end
            end
        end
    else
        restoreOriginalSettings()
    end
end

local function applyUltraMode(enabled)
    if enabled then
        if next(originalSettings) == nil then saveOriginalSettings() end
        applyAntiLag(true)

        originalDescendants = {}
        for _, v in ipairs(Workspace:GetDescendants()) do
            if v:IsA("ParticleEmitter") or v:IsA("Trail") or v:IsA("Beam") then
                table.insert(originalDescendants, {obj = v, Enabled = v.Enabled})
                v.Enabled = false
            end
            
            if (v:IsA("Accessory") or v:IsA("MeshPartAccessory")) and not v.Name:lower():find("hair") then
                pcall(function()
                    table.insert(originalDescendants, {obj = v, Parent = v.Parent})
                    v.Parent = nil
                end)
            end
        end
    else
        for _, data in ipairs(originalDescendants) do
            if data.obj and data.obj.Parent == nil then
                pcall(function() data.obj.Parent = data.Parent end)
            elseif data.obj and data.Enabled ~= nil then
                data.obj.Enabled = data.Enabled
            end
        end
        originalDescendants = {}
        restoreOriginalSettings()
    end
end

-- ====================== GUI ======================
if CoreGui:FindFirstChild("PulseInstaGrab") then 
    CoreGui.PulseInstaGrab:Destroy() 
end

